generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  PRINCIPAL
  STUDENT
}

enum Status {
  AKTIF
  ARSIP
  BELUM
  SUDAH
}

enum JenisKalender {
  HARI_EFEKTIF
  LIBUR_NASIONAL
  LIBUR_SEKOLAH
  KEGIATAN
  UJIAN
}

enum JenisPenilaian {
  UH
  TUGAS
  STS
  SAS
  SIKAP
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  role         UserRole  @default(TEACHER)
  nip          String?
  photoUrl     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  teacher      Teacher?
  journals     Journal[]
  grades       Grade[]
}

model Teacher {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kodeGuru      String    @unique
  tanggalLahir  String?
  mataPelajaran String?
  jenisKelamin  String?
  // Store as comma-separated strings for simplicity
  tingkatKelas  String?
  jurusan       String?

  // Relations
  schedules     Schedule[]
  classPicketSchedules ClassPicketSchedule[]
  classPicketReports ClassPicketReport[]
  religiousPicketSchedules ReligiousPicketSchedule[]
  religiousPicketReports ReligiousPicketReport[]
  curriculumSubmissions CurriculumSubmission[]
  guidanceBookEntries GuidanceBookEntry[]
  journals      Journal[]
  grades        Grade[]
  teachingObjectives TeachingObjective[]
  teachingAssignments TeachingAssignment[]
  homeroomClasses ClassMajor[] @relation("HomeroomTeacherAssignments")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TeachingAssignment {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject     String
  className   String
  classLevel  String
  majorCode   String
  majorName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teacherId, subject, className])
  @@index([teacherId, subject])
  @@index([teacherId, className])
}

model Subject {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ClassMajor {
  id               String    @id @default(cuid())
  className        String    @unique
  grade            String    // X, XI, XII
  majorCode        String    // TKJ, TKR, RPL, DKV
  majorName        String?
  bidangKeahlian   String?   // Data jurusan untuk raport
  programKeahlian  String?   // Data jurusan untuk raport
  konsentrasiKeahlian String? // Data jurusan untuk raport
  homeroomTeacher  String?
  homeroomTeacherId String?
  homeroomTeacherProfile Teacher? @relation("HomeroomTeacherAssignments", fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  room             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Student {
  id          String    @id @default(cuid())
  nis         String    @unique
  nisn        String?
  name        String
  gender      String?
  className   String?
  classId     String?
  birthPlace  String?
  birthDate   String?
  address     String?
  phone       String?
  email       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  grades      Grade[]
  reportCardSupplements ReportCardSupplement[]
}

model Curriculum {
  id                  String   @id @default(cuid())
  competency          String
  subject             String
  gradeLevel          String
  semester            String
  cp                  String   // Capaian Pembelajaran
  tp                  String   // Tujuan Pembelajaran
  atp                 String   // Alur Tujuan Pembelajaran
  timeAllocation      Int
  academicYear        String
  status              Status   @default(AKTIF)
  documentUrl         String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  journals            Journal[]
}

model GuidanceBookEntry {
  id          String   @id @default(cuid())
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  teacherName String
  day         String
  date        String
  keterangan  String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([teacherId, date])
}

model Schedule {
  id          String   @id @default(cuid())
  day         String
  period      Int
  startTime   String
  endTime     String
  classLevel  String
  subject     String
  teacherId   String
  room        String
  academicYear String
  semester    String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model ClassPicketSchedule {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  day         String
  weekLabel   String
  month       String
  year        String
  classNames  String
  reports     ClassPicketReport[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId, year, month, weekLabel, day])
}

model ClassPicketReport {
  id          String   @id @default(cuid())
  scheduleId  String
  schedule    ClassPicketSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  reportDate  String
  className   String
  period      String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scheduleId, reportDate, className, period])
  @@index([reportDate, scheduleId])
  @@index([teacherId, reportDate])
}

model AIScheduleConfig {
  id                          String   @id @default(cuid())
  scope                       String   @unique @default("default")
  academicYear                String
  semester                    String   @default("Ganjil")
  scheduleTeachersJson        String
  dayTimeSlotsJson            String
  religiousRestrictionsJson   String
  prioritiesJson              String
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model ReligiousPicketSchedule {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  day         String
  weekLabel   String
  month       String
  year        String
  reports     ReligiousPicketReport[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId, year, month, weekLabel, day])
}

model ReligiousPicketReport {
  id          String   @id @default(cuid())
  scheduleId  String
  schedule    ReligiousPicketSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  reportDate  String
  status      String
  checkInTime String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scheduleId, reportDate])
  @@index([teacherId, reportDate])
}

model CurriculumSubmission {
  id             String   @id @default(cuid())
  category       String
  teacherId      String?
  teacher        Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  teacherName    String
  subject        String
  grade          String
  major          String
  majorCode      String
  className      String
  tool           String
  fileName       String
  fileUrl        String?
  filePath       String?
  fileMimeType   String?
  fileSize       Int?
  storageProvider String? @default("vercel-blob")
  status         String
  submissionDate String
  verifiedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  activities     CurriculumActivity[]

  @@index([category, createdAt])
  @@index([category, teacherId])
  @@index([category, teacherName])
}

model CurriculumActivity {
  id             String   @id @default(cuid())
  category       String
  submissionId   String?
  submission     CurriculumSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  actorName      String
  teacherName    String
  action         String
  subject        String
  timestampLabel String
  type           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category, createdAt])
  @@index([submissionId])
}

model Journal {
  id              String   @id @default(cuid())
  date            DateTime
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classLevel      String
  subject         String
  semester        String
  academicYear    String
  jamKe           String?
  material        String
  tpAchieved      String?
  curriculumId    String?
  curriculum      Curriculum? @relation(fields: [curriculumId], references: [id])
  method          String    @default("")
  presentCount    Int       @default(0)
  absentCount     Int       @default(0)
  issues          String?
  notes           String?
  verifyStatus    Status   @default(BELUM)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Grade {
  id              String        @id @default(cuid())
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject         String
  classLevel      String        // Kelas (X/XI/XII)
  major           String        // Jurusan (TKJ/TKR/RPL/DKV)
  jenisPenilaian  JenisPenilaian // UH/TUGAS/STS/SAS/SIKAP
  semester        String

  // Nilai sesuai jenis penilaian
  nilai1          String?       // Untuk UH1, Tugas1
  nilai2          String?       // Untuk UH2, Tugas2
  nilai3          String?       // Untuk UH3, Tugas3
  nilaiAkhir      String?       // Untuk STS/SAS/Sikap atau rata-rata

  teacherId       String
  teacher         Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CalendarEvent {
  id          String         @id @default(cuid())
  date        DateTime
  description String
  type        JenisKalender
  applicable  String
  semester    String

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TeachingObjective {
  id            String   @id @default(cuid())
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject       String
  className     String
  academicYear  String
  semester      String
  objectiveText String
  orderNo       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([teacherId, subject, className, academicYear, semester, orderNo])
  @@index([teacherId, academicYear, semester, className, subject])
}

model ReportCardSupplement {
  id                    String   @id @default(cuid())
  studentId             String
  student               Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear          String
  semester              String
  className             String?
  sakit                 Int      @default(0)
  izin                  Int      @default(0)
  alpha                 Int      @default(0)
  developmentPramuka    String?  @default("-")
  developmentSholatDhuha String? @default("-")
  personalityAkhlak     String?  @default("-")
  personalityKerajinan  String?  @default("-")
  personalityKerapian   String?  @default("-")
  homeroomNote          String?  @default("")
  reportCity            String?  @default("Pacet")
  reportDate            String?  @default("")
  homeroomSignatureName String?  @default("")
  homeroomSignatureTitle String? @default("Wali Kelas")
  principalSignatureName String? @default("Kepala SMKS PACET")
  principalSignatureTitle String? @default("Kepala Sekolah")
  principalNip          String?  @default("")
  isFinalized           Boolean  @default(false)
  finalizedAt           DateTime?
  finalizedByUserId     String?
  updatedByUserId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([studentId, academicYear, semester])
}
