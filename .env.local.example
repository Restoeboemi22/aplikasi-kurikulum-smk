# Variabel lingkungan Firebase — SALIN file ini menjadi `.env.local`
# lalu isi nilainya dari Firebase Console (Project settings > General > Your apps > SDK setup and configuration).
# CATATAN: prefix NEXT_PUBLIC_ wajib agar bisa dibaca di browser.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
